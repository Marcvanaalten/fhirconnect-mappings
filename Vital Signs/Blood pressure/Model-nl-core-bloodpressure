grammar: FHIRConnect/v1.0.0
type: model
metadata:
  name: OBSERVATION.blood_pressure.v2
  version: 0.0.1-alpha
spec:
  system: FHIR
  version: R4
  openEhrConfig:
    archetype: openEHR-EHR-OBSERVATION.blood_pressure.v2
  fhirConfig:
    structureDefinition: http://hl7.org/fhir/StructureDefinition/Observation

preprocessor:
  fhirConditions:
    - targetRoot: "$resource"
      targetAttribute: code.coding.code
      operator: one of
      criteria: 85354-9

mappings:
  - name: id
    with:
      fhir: "$resource"
      openehr: "$archetype"
    unidirectional: "openehr->fhir"
    manual:
      - name: "id"
        fhir:
          - path: "id"
            value: "nl-core-BloodPressure-01"

  - name: meta
    with:
      fhir: "$resource.meta"
      openehr: "$archetype"
    unidirectional: "openehr->fhir"
    manual:
      - name: "profile"
        fhir:
          - path: "profile"
            value: "http://nictiz.nl/fhir/StructureDefinition/nl-core-BloodPressure"

  - name: fhirStatus
    with:
      fhir: "$resource"
      openehr: "$archetype"
    unidirectional: "openehr->fhir"
    manual:
      - name: "status"
        fhir:
          - path: "status"
            value: "final"

  - name: manualLoincCode
    with:
      fhir: "$resource.code.coding"
      openehr: "$archetype"
    unidirectional: "openehr->fhir"
    manual:
      - name: "coding"
        fhir:
          - path: "code"
            value: "85354-9"
          - path: "system"
            value: "http://loinc.org"
          - path: "display"
            value: "Blood pressure panel with all children optional"

  - name: method
    with:
      fhir: "$resource.method"
      openehr: "$archetype/protocol[at0011]/items[at1035]"
      type: CODEABLECONCEPT

  - name: observationCategory
    with:
      fhir: "$resource.category.coding"
      openehr: "$archetype"
    unidirectional: "openehr->fhir"
    manual:
      - name: "category"
        fhir:
          - path: "system"
            value: "http://terminology.hl7.org/CodeSystem/observation-category"
          - path: "code"
            value: "vital-signs"
          - path: "display"
            value: "Vital Signs"

  - name: bodySite
    with:
      fhir: "$resource.bodySite"
      openehr: "$archetype/protocol[at0011]/items[at0014]"
      type: CODEABLECONCEPT

  - name: position
    with:
      fhir: "$resource.extension"
      openehr: "$archetype"
    fhirCondition:
      targetRoot: "$resource.extension"
      targetAttribute: "url"
      operator: one of
      criteria: "http://hl7.org/fhir/StructureDefinition/observation-bodyPosition"
    followedBy:
        mappings:
        - name: positionValue
          with:
            fhir: "value"
            openehr: "$archetype/data[at0001]/events[at0006]/state[at0007]/items[at0008]"

        - name: hardcodedPositionURL
          with:
            fhir: "$fhirRoot"
            openehr: "$openehrRoot"
          unidirectional: "openehr->fhir"
          manual:
            - name: "url"
              fhir:
                - path: "url"
                  value: "http://hl7.org/fhir/StructureDefinition/observation-bodyPosition"

  - name: dateTime
    with:
      fhir: "$resource.effective"
      openehr: "$archetype/data[at0001]/events[at0006]/time"
      type: DATETIME

  - name: "systolic"
    with:
      fhir: "$resource.component"
      openehr: "$archetype/data[at0001]/events[at0006]/data[at0003]"
    fhirCondition:
      targetRoot: "$resource.component"                       
      targetAttribute: "code.coding.code" 
      operator: "one of"
      criteria: "8480-6"
    followedBy:
      mappings:
        - name: "value"
          with:
            fhir: "value"
            openehr: "items[at0004]"
        - name: "loincCode"
          with:
            fhir: "code.coding."
            openehr: "$archetype"
          unidirectional: "openehr->fhir"
          manual:
            - name: "loincCodeManual"
              fhir:
                - path: "code"
                  value: "8480-6"
                - path: "system"
                  value: "http://loinc.org"
                - path: "display"
                  value: "Systolic blood pressure"

  - name: "diastolic"
    with:
      fhir: "$resource.component"
      openehr: "$archetype/data[at0001]/events[at0006]/data[at0003]"
    fhirCondition:
      targetRoot: "$resource.component"                       
      targetAttribute: "code.coding.code" 
      operator: "one of"
      criteria: "8462-4"
    followedBy:
      mappings:
        - name: "value"
          with:
            fhir: "value"
            openehr: "items[at0005]"
        - name: "loincCode"
          with:
            fhir: "code.coding"
            openehr: "$archetype"
          unidirectional: "openehr->fhir"
          manual:
            - name: "loincCodeManual"
              fhir:
                - path: "code"
                  value: "8462-4"
                - path: "system"
                  value: "http://loinc.org"
                - path: "display"
                  value: "Diastolic blood pressure"

  - name: averageBloodPressure
    with:
      fhir: "resource.component"
      openehr: "$archetype/data[at0001]/events[at0006]/data[at0003]"
    fhirCondition:
      targetRoot: "resource.component"
      targetAttribute: "code.coding.code"
      operator: "one of"
      criteria: "6797001"
    followedBy:
      mappings:
        - name: averageBloodPressure
          with:
            fhir: "value"
            openehr: "items[at1006]"
            type: QUANTITY
        - name: "loincCode"
          with:
            fhir: "code.coding."
            openehr: "$archetype"
          unidirectional: "openehr->fhir"
          manual:
            - name: "loincCodeManual"
              fhir:
                - path: "code"
                  value: "6797001"
                - path: "system"
                  value: "http://snomed.info/sct"
                - path: "display"
                  value: "gemiddelde bloeddruk (waarneembare entiteit)"
    
  - name: cuffTypeParent
    with:
      fhir: "$resource.component"
      openehr: "$archetype/protocol[at0011]/items[at0013]"
    fhirCondition:
      targetRoot: "$resource.component"
      targetAttribute: "code.coding.code"
      operator: one of
      criteria: '70665002'
    followedBy:
      mappings:
        - name: cufftype
          with:
            fhir: "value.as(CodeableConcept)"
            openehr: "$openehrRoot"
          terminology:
              type: "local"
              conceptmap: "http://interoplab.eu/fhir/ConceptMap/cuffsizeBloodpressure"

        - name: "harcdcodingcuffType"
          with:
            fhir: "code.coding"
            openehr: "$openehrRoot"
          unidirectional: "openehr->fhir"
          manual:
            - name: "coding"
              fhir:
                - path: "code"
                  value: "70665002"
                - path: "system"
                  value: "http://snomed.info/sct"
                - path: "display"
                  value: "Blood pressure cuff"

  - name: diastolicEndpointParent
    with:
      fhir: "$resource.component"
      openehr: "$archetype/protocol[at0011]/items[at1010]"
    fhirCondition:
      targetRoot: "$resource.component"
      targetAttribute: "code.coding.code"
      operator: one of
      criteria: '85549003'
    followedBy:
      mappings:
        - name: "harcdcodingComponentCodeDiastolicEndpoint"
          with:
            fhir: "code.coding"
            openehr: "$openehrRoot"
          unidirectional: "openehr->fhir"
          manual:
            - name: "coding"
              fhir:
                - path: "code"
                  value: "85549003"
                - path: "system"
                  value: "http://snomed.info/sct"
                - path: "display"
                  value: "Korotkofftonen (waarneembare entiteit)"

        - name: diastolicEndpoint
          with:
            fhir: "value"
            openehr: "$openehrRoot"
            type: CODEABLECONCEPT

